# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ── Virtual environments ────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Test / tooling caches ───────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Local config / secrets ──────────────────────────────
.env
.env.*
!.env.example

# ── Data (runtime artifacts; keep the dir, ignore contents) ──
data/*
!data/.gitkeep

# ── OS / editor cruft ───────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
